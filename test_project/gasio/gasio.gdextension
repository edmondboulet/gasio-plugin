[configuration]
entry_symbol = "gasio_init"
compatibility_minimum = "4.6"

[libraries]
; Relative paths ensure that our GDExtension can be placed anywhere in the project directory.
macos.debug = "./bin/macos/libgasio.macos.template_debug.single.framework"
macos.release = "./bin/macos/libgasio.macos.template_release.single.framework"


ios.debug = "./bin/ios/libgasio.ios.template_debug.single.xcframework"
ios.release = "./bin/ios/libgasio.ios.template_release.single.xcframework"


windows.debug.x86_32 = "./bin/windows/gasio.windows.template_debug.x86_32.single.dll"
windows.release.x86_32 = "./bin/windows/gasio.windows.template_release.x86_32.single.dll"

windows.debug.x86_64 = "./bin/windows/gasio.windows.template_debug.x86_64.single.dll"
windows.release.x86_64 = "./bin/windows/gasio.windows.template_release.x86_64.single.dll"

windows.debug.arm64 = "./bin/windows/gasio.windows.template_debug.arm64.single.dll"
windows.release.arm64 = "./bin/windows/gasio.windows.template_release.arm64.single.dll"


; NOTE: Linux is intentionally omitted — the ASIO SDK depends on windows.h, COM,
; and the Windows registry, so no Linux library exists. Declaring linux.* paths
; here makes the exporter fail trying to copy a .so that can't be built.


android.debug.x86_64 = "./bin/android/libgasio.android.template_debug.x86_64.single.so"
android.release.x86_64 = "./bin/android/libgasio.android.template_release.x86_64.single.so"

android.debug.arm64 = "./bin/android/libgasio.android.template_debug.arm64.single.so"
android.release.arm64 = "./bin/android/libgasio.android.template_release.arm64.single.so"

android.debug.arm32 = "./bin/android/libgasio.android.template_debug.arm32.single.so"
android.release.arm32 = "./bin/android/libgasio.android.template_release.arm32.single.so"


web.debug.threads.wasm32 = "./bin/web/libgasio.web.template_debug.wasm32.threads.single.wasm"
web.release.threads.wasm32 = "./bin/web/libgasio.web.template_release.wasm32.threads.single.wasm"

web.debug.wasm32 = "./bin/web/libgasio.web.template_debug.wasm32.single.wasm"
web.release.wasm32 = "./bin/web/libgasio.web.template_release.wasm32.single.wasm"

[dependencies]
ios.debug = {
  "./bin/ios/libgasio.ios.template_debug.single.xcframework": ""
}
ios.release = {
  "./bin/ios/libgasio.ios.template_release.single.xcframework": ""
}
